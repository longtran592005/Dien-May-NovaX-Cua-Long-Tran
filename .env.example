# Application
NODE_ENV=development
APP_NAME=novax-commerce
APP_PORT=3000
API_GATEWAY_PORT=8080

# Frontend
VITE_APP_NAME=NovaX
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_AI_BASE_URL=http://localhost:3000/ai
EDGE_PORT=3000

# Auth
JWT_ACCESS_SECRET=replace_with_access_secret
JWT_REFRESH_SECRET=replace_with_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=12

# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=novax
POSTGRES_USER=novax_user
POSTGRES_PASSWORD=replace_with_db_password
DATABASE_URL=postgresql://novax_user:replace_with_db_password@localhost:5432/novax?schema=public

# Cache/Queue
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# AI
OPENAI_API_KEY=replace_with_openai_key
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4.1-mini
VECTOR_PROVIDER=pgvector

# Storage
S3_ENDPOINT=
S3_REGION=ap-southeast-1
S3_BUCKET=novax-assets
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Payments
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=http://localhost:3000/payment/callback
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_REDIRECT_URL=http://localhost:3000/payment/callback

# Email
EMAIL_FROM=NovaX <no-reply@novax.local>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=info

# Security
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Maps - OpenStreetMap (Completely Free, No API Key Required!)
# Sử dụng OpenStreetMap với Nominatim - Hoàn toàn miễn phí, không cần API key
# Cấu hình Google Maps không còn cần thiết
# VITE_GOOGLE_MAPS_API_KEY=not_needed_anymore_use_openstreetmap
