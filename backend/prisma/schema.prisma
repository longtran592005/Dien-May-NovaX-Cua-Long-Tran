generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// UserRole ENUM mapped to String: "customer", "admin"
// OrderStatus ENUM mapped to String: "pending", "confirmed", "processing", "shipped", "delivered", "cancelled"
// PaymentMethod ENUM mapped to String: "cod", "vnpay", "momo"
// PaymentStatus ENUM mapped to String: "pending", "processing", "completed", "failed", "refunded"

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  phone              String?
  fullName           String?
  passwordHash       String?
  googleId           String?   @unique
  role               String    @default("customer")
  verified           Boolean   @default(false)
  confirmationCode   String?
  points             Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  carts              Cart[]
  orders             Order[]
  addresses          Address[]
  reviews            ProductReview[]
  savedCards         SavedCard[]
  refreshTokens      RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  icon      String?
  parentId  String?
  parent    Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id            String     @id @default(uuid())
  name          String
  slug          String     @unique
  description   String?
  price         Int
  originalPrice Int?
  discount      Int?
  brand         String
  sku           String?    @unique
  rating        Float      @default(0)
  reviewCount   Int        @default(0)
  inStock       Boolean    @default(true)
  stock         Int        @default(0)
  minStockThreshold Int    @default(5)
  reorderTarget Int        @default(20)
  isActive      Boolean    @default(true)
  categoryId    String
  category      Category   @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  orderItems    OrderItem[]
  reviews       ProductReview[]
  stocks        StoreStock[]
  warranties    Warranty[]
  warehouseInventory WarehouseProduct[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([stock])
  @@index([minStockThreshold])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Cart {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId])
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

model Address {
  id            String   @id @default(uuid())
  userId        String
  fullName      String
  phone         String
  province      String
  district      String
  ward          String
  streetAddress String
  label         String   @default("Home") // House, Office, etc.
  isDefault     Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        Order[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id                String        @id @default(uuid())
  orderNumber       String        @unique
  userId            String
  status            String        @default("pending")
  subtotal          Int
  shippingFee       Int           @default(0)
  discountAmount    Int           @default(0)
  usedPoints        Int           @default(0)
  total             Int
  pricingSnapshot   Json?
  shippingAddressId String
  deliveryMethod    String        @default("standard") // standard, express_2h, pickup
  note              String?
  user              User          @relation(fields: [userId], references: [id])
  shippingAddress   Address       @relation(fields: [shippingAddressId], references: [id])
  items             OrderItem[]
  warranties        Warranty[]
  shipment          OrderShipment?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  productId  String
  quantity  Int
  unitPrice  Int
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique
  amount        Int
  method        String
  status        String        @default("pending")
  transactionRef String?
  // Removed order relation to allow payment creation without order existing
  // In production, consider adding order validation at service layer
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ProductReview {
  id          String   @id @default(uuid())
  userId      String
  productId   String
  rating      Int
  comment     String?
  isVerified  Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, productId])
}

model Store {
  id        String   @id @default(uuid())
  name      String
  address   String
  province  String
  district  String
  phone     String?
  stocks    StoreStock[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreStock {
  id        String   @id @default(uuid())
  productId String
  storeId   String
  quantity  Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([productId, storeId])
}

model SavedCard {
  id        String   @id @default(uuid())
  userId    String
  brand     String
  last4     String
  token     String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Warranty {
  id           String   @id @default(uuid())
  orderId      String
  productId    String
  expiryDate   DateTime
  serialNumber String   @unique
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id])
  createdAt    DateTime @default(now())
}

model Promotion {
  id             String                   @id @default(uuid())
  name           String
  code           String?                  @unique
  type           String
  status         String                   @default("draft")
  discountType   String
  discountValue  Int
  maxDiscount    Int?
  minOrderAmount Int?
  priority       Int                      @default(100)
  isExclusive    Boolean                  @default(false)
  startsAt       DateTime
  endsAt         DateTime
  usageLimit     Int?
  usedCount      Int                      @default(0)
  targetTier     String?
  metadata       Json?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  productScopes  PromotionProductScope[]
  categoryScopes PromotionCategoryScope[]
  promotionAudits PromotionAudit[]

  @@index([status, startsAt, endsAt])
  @@index([type, status])
}

model PromotionProductScope {
  id           String    @id @default(uuid())
  promotionId  String
  productId    String
  minQuantity  Int       @default(1)
  bonusProduct String?
  createdAt    DateTime  @default(now())
  promotion    Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([promotionId, productId])
  @@index([productId])
}

model PromotionCategoryScope {
  id           String    @id @default(uuid())
  promotionId  String
  categorySlug String
  createdAt    DateTime  @default(now())
  promotion    Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([promotionId, categorySlug])
  @@index([categorySlug])
}

model ShippingZone {
  id           String          @id @default(uuid())
  name         String          // "Zone 1: Nội thành HN", "Zone 2: Ngoại thành HN"
  provinceCode String?         // Vietnam province code for primary matching
  slug         String          @unique
  priority     Int             @default(100) // Lower = higher priority
  rules        ShippingRule[]
  shipments    OrderShipment[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([slug])
}

model ShippingRule {
  id           String         @id @default(uuid())
  zoneId       String
  zone         ShippingZone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  // Distance based: 0-5km, 5-10km, 10-20km, 20+km (null = applies to all)
  minDistance  Int?           // km
  maxDistance  Int?           // km, null = no upper limit
  // Weight based: lightweight, standard, bulky
  minWeight    Int?           // grams
  maxWeight    Int?           // grams, null = no upper limit
  // Fee calculation
  baseFee      Int            // base shipping fee in VND
  perKmFee     Int            @default(0) // additional fee per km
  weightFactor Int            @default(0) // additional fee per 1000g
  bulkyFactor  Float          @default(1.0) // multiplier for bulky items
  maxFee       Int?           // cap on shipping fee
  minOrderAmount Int?         // minimum order to apply rule
  // Metadata
  description  String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([zoneId, minDistance, maxDistance, minWeight, maxWeight])
  @@index([zoneId])
  @@index([isActive])
}

model Warehouse {
  id           String            @id @default(uuid())
  name         String
  code         String            @unique
  province     String
  district     String
  address      String
  phone        String?
  isPrimary    Boolean           @default(false) // Default allocation target
  capacity     Int?              // Total capacity in units
  inventory    WarehouseProduct[]
  shipments    OrderShipment[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([province, district])
  @@index([isPrimary])
}

model WarehouseProduct {
  id         String    @id @default(uuid())
  warehouseId String
  warehouse  Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId  String
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity   Int       @default(0)
  reserved   Int       @default(0) // Reserved for pending orders
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([warehouseId, productId])
  @@index([productId])
}

model OrderShipment {
  id              String    @id @default(uuid())
  orderId         String    @unique
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  shippingZoneId  String
  shippingZone    ShippingZone @relation(fields: [shippingZoneId], references: [id])
  estimatedDays   Int       // e.g., 2-3 days
  shippingFee     Int       // calculated fee in VND
  trackingNumber  String?
  status          String    @default("pending") // pending, processing, picked, shipped, delivered, failed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([orderId])
  @@index([warehouseId])
  @@index([status])
}

model InventoryMovement {
  id           String   @id @default(uuid())
  productId    String
  warehouseId  String?
  orderId      String?
  movementType String
  quantity     Int
  reason       String?
  source       String?
  createdAt    DateTime @default(now())

  @@index([productId, createdAt])
  @@index([warehouseId, createdAt])
  @@index([orderId])

}

model PromotionAudit {
  id          String   @id @default(uuid())
  promotionId String
  orderId     String
  userId      String?
  amount      Int      @default(0)
  metadata    Json?
  createdAt   DateTime @default(now())

  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([promotionId])
  @@index([orderId])
}


model SalesSnapshotDaily {
  id            String   @id @default(uuid())
  snapshotDate  DateTime @unique
  metricMode    String
  orderCount    Int      @default(0)
  revenue       Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([metricMode, snapshotDate])
}

model InventorySnapshotDaily {
  id               String   @id @default(uuid())
  snapshotDate     DateTime
  productId        String
  warehouseId      String?
  stockOnHand      Int      @default(0)
  reserved         Int      @default(0)
  minStockThreshold Int     @default(5)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([snapshotDate, productId, warehouseId])
  @@index([snapshotDate])
  @@index([productId, snapshotDate])
}

